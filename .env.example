# SkillBridge API - Environment Variables Template
# Copy this file to .env and fill in your actual values

# Database Configuration
# For local PostgreSQL: postgresql://username:password@localhost:5432/skillbridge
# For Neon: postgresql://user:password@ep-xxxx.region.neon.tech/dbname
DATABASE_URL=postgresql+psycopg2://skillbridge_user:StrongPassword123!@localhost:5432/skillbridge_prod

# JWT Configuration
SECRET_KEY=your-super-secret-key-change-this-in-production
ALGORITHM=HS256

# Token Expiry
ACCESS_TOKEN_EXPIRE_HOURS=24
MONITORING_TOKEN_EXPIRE_MINUTES=60

# Monitoring Officer API Key
# This is the API key required to generate monitoring-scoped tokens
MONITORING_API_KEY=skillbridge-monitoring-key-12345

# Environment
DEBUG=False
